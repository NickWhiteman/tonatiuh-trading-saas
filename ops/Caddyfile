  email {$ACME_EMAIL}
  admin off
}

{$DOMAIN} {
  encode zstd gzip
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    -Server
  }
  reverse_proxy api:3131 {
    health_uri /health/ready
    health_interval 15s
    health_timeout 3s
  }
  log {
    output stdout
    format json
  }
}
