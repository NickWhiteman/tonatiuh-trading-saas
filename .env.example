APP_MODE=web
ENV_RELEASE=dev
PORT=3131

DATABASE_URL=postgres://tonatiuh:change-me@localhost:5432/tonatiuh
DATABASE_POOL_SIZE=20
DATABASE_IDLE_TIMEOUT_MS=30000

JWT_SECRET=replace-with-at-least-32-random-bytes
