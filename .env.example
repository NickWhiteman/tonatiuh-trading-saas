ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Generate unique production secrets; never commit real values.
ENCRYPTION_KEY=replace-with-a-random-32-byte-key
TONATIUH_API_TOKEN=replace-with-a-long-random-token
TRADING_EXCHANGE=
TRADING_API_KEY=
TRADING_SECRET_KEY=
