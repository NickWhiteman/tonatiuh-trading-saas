APP_MODE=web
ENV_RELEASE=dev
PORT=3131
HOST=0.0.0.0

DATABASE_URL=postgres://tonatiuh:change-me@localhost:5432/tonatiuh
COMPOSE_DATABASE_URL=postgres://tonatiuh:change-me@postgres:5432/tonatiuh
POSTGRES_PASSWORD=change-me
DATABASE_POOL_SIZE=20
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000
# Set on runtime processes after migrations: tonatiuh_api or tonatiuh_worker.
DATABASE_ROLE=tonatiuh_api

JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ISSUER=tonatiuh-trading-saas
JWT_AUDIENCE=tonatiuh-trading-api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
TERMS_VERSION=2026-01
PRIVACY_VERSION=2026-01
RETENTION_WORKER_INTERVAL_MS=86400000

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://app.example.com/billing/return
PRO_PLAN_NAME=Tonatiuh Pro
PRO_PRICE_KOPECKS=99000
YOOKASSA_SEND_RECEIPT=false
YOOKASSA_VAT_CODE=1
BILLING_WORKER_INTERVAL_MS=30000
BILLING_GRACE_PERIOD_DAYS=7
BILLING_RETRY_SCHEDULE_HOURS=1,24,72,120
BILLING_RECONCILIATION_MINUTES=10

PUBLIC_APP_URL=https://app.example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Tonatiuh <no-reply@example.com>
EMAIL_WORKER_INTERVAL_MS=5000
DEFAULT_EMAIL_LOCALE=ru
EMAIL_WEBHOOK_TOKEN=replace-with-a-long-random-token
CORS_ORIGINS=https://app.example.com
TRUST_PROXY=1
LOG_LEVEL=info
METRICS_TOKEN=replace-with-a-long-random-token

# Generate unique production secrets; never commit real values.
ENCRYPTION_KEY=replace-with-64-hexadecimal-characters
ENCRYPTION_KEY_ID=primary-v1
TONATIUH_API_TOKEN=replace-with-a-long-random-token
SAAS_BOT_DATA_DIR=./saas-bot-data
SAAS_WORKER_POLL_MS=1000
SAAS_WORKER_STOP_TIMEOUT_MS=10000
TRADING_EXCHANGE=
TRADING_API_KEY=
TRADING_SECRET_KEY=
