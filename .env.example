APP_MODE=web
ENV_RELEASE=dev
PORT=3131

DATABASE_URL=postgres://tonatiuh:change-me@localhost:5432/tonatiuh
DATABASE_POOL_SIZE=20
DATABASE_IDLE_TIMEOUT_MS=30000

JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ISSUER=tonatiuh-trading-saas
JWT_AUDIENCE=tonatiuh-trading-api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://app.example.com/billing/return
PRO_PLAN_NAME=Tonatiuh Pro
PRO_PRICE_KOPECKS=99000
YOOKASSA_SEND_RECEIPT=false
YOOKASSA_VAT_CODE=1
BILLING_WORKER_INTERVAL_MS=30000

# Generate unique production secrets; never commit real values.
ENCRYPTION_KEY=replace-with-64-hexadecimal-characters
ENCRYPTION_KEY_ID=primary-v1
TONATIUH_API_TOKEN=replace-with-a-long-random-token
SAAS_BOT_DATA_DIR=./saas-bot-data
SAAS_WORKER_POLL_MS=1000
SAAS_WORKER_STOP_TIMEOUT_MS=10000
TRADING_EXCHANGE=
TRADING_API_KEY=
TRADING_SECRET_KEY=
