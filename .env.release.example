# Non-secret, per-release evidence consumed by `npm run release:check`.
RELEASE_COMMIT_SHA=0123456789abcdef0123456789abcdef01234567
IMAGE_DIGEST=sha256:replace-with-64-lowercase-hex-characters
PREVIOUS_IMAGE_DIGEST=sha256:replace-with-previous-64-lowercase-hex-digest
RESTORE_DRILL_AT=2026-07-22T00:00:00Z
MIGRATION_REVIEWED_BY=github-login
SECURITY_REVIEWED_BY=github-login
ON_CALL_OWNER=on-call-name
CHANGE_TICKET_URL=https://changes.example.com/releases/123
