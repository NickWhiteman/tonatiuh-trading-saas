APP_MODE=web
ENV_RELEASE=prod
HOST=0.0.0.0
PORT=3131
DOMAIN=api.example.com
ACME_EMAIL=ops@example.com
IMAGE_REPOSITORY=ghcr.io/example/tonatiuh-trading-saas
IMAGE_TAG=sha-immutable-digest
POSTGRES_TOOLS_IMAGE=ghcr.io/example/tonatiuh-trading-saas-postgres-tools
POSTGRES_TOOLS_TAG=sha-immutable-digest
BACKUP_RETENTION_DAYS=35
BACKUP_PRUNE=false
BACKUP_VOLUME_NAME=tonatiuh-backups
CORS_ORIGINS=https://app.example.com
PUBLIC_APP_URL=https://app.example.com
TRUST_PROXY=1
LOG_LEVEL=info
TERMS_VERSION=2026-01
PRIVACY_VERSION=2026-01
TERMS_URL=https://app.example.com/legal/terms/2026-01
PRIVACY_URL=https://app.example.com/legal/privacy/2026-01
# Replace with the SHA-256 of the exact immutable documents before deployment.
TERMS_SHA256=replace-with-64-lowercase-hex-characters
PRIVACY_SHA256=replace-with-64-lowercase-hex-characters
CONSENT_EVIDENCE_KEY_ID=consent-v1
RETENTION_WORKER_INTERVAL_MS=86400000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_FROM=Tonatiuh <no-reply@example.com>
DEFAULT_EMAIL_LOCALE=ru
YOOKASSA_SHOP_ID=
YOOKASSA_RETURN_URL=https://app.example.com/billing/return
BILLING_GRACE_PERIOD_DAYS=7
BILLING_RETRY_SCHEDULE_HOURS=1,24,72,120
BILLING_RECONCILIATION_MINUTES=10
