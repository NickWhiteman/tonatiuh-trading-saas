  "schemas": {
    "ErrorResponse": {
      "type": "object",
      "required": [
        "error"
      ],
      "properties": {
        "error": {
          "type": "object",
          "required": [
            "code",
            "message",
            "requestId"
          ],
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "requestId": {
              "type": "string"
            },
            "details": {}
          }
        }
      }
    },
    "Session": {
      "type": "object",
      "required": [
        "accessToken",
        "refreshToken",
        "expiresIn"
      ],
      "properties": {
        "accessToken": {
          "type": "string",
          "writeOnly": true
        },
        "refreshToken": {
          "type": "string",
          "writeOnly": true
        },
        "expiresIn": {
          "type": "integer"
        }
      }
    },
    "AssignableRole": {
      "type": "string",
      "enum": [
        "ADMIN",
        "TRADER",
        "ANALYST",
        "BILLING",
        "VIEWER"
      ]
    },
    "Register": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "email",
        "password",
        "displayName",
        "acceptTerms",
        "acceptPrivacy"
      ],
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "maxLength": 320
        },
        "password": {
          "type": "string",
          "format": "password",
          "minLength": 12,
          "maxLength": 128
        },
        "displayName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "organizationName": {
          "type": "string",
          "maxLength": 120
        },
        "acceptTerms": {
          "type": "boolean"
        },
        "acceptPrivacy": {
          "type": "boolean"
        }
      }
    },
    "Login": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "email",
        "password"
      ],
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "password": {
          "type": "string",
          "format": "password"
        }
      }
    },
    "ExchangeConnectionInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exchange",
        "label",
        "apiKey",
        "secret"
      ],
      "properties": {
        "exchange": {
          "type": "string",
          "enum": [
            "okx",
            "binance",
            "bitget",
            "kucoin",
            "mexc",
            "poloniex",
            "gate",
            "exmo",
            "bybit"
          ]
        },
        "label": {
          "type": "string"
        },
        "apiKey": {
          "type": "string",
          "writeOnly": true
        },
        "secret": {
          "type": "string",
          "writeOnly": true
        },
        "password": {
          "type": "string",
          "writeOnly": true
        },
        "sandbox": {
          "type": "boolean"
        },
        "verify": {
          "type": "boolean"
        }
      }
    },
    "BotInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exchangeConnectionId",
        "name",
        "configuration"
      ],
      "properties": {
        "exchangeConnectionId": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "strategy": {
          "type": "string",
          "enum": [
            "VECTOR_PROFIT"
          ]
        },
        "configuration": {
          "$ref": "#/components/schemas/TradingConfiguration"
        }
      }
    },
    "TradingConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol"
      ],
      "properties": {
        "symbol": {
          "type": "string",
          "pattern": "^[A-Z0-9]{2,12}/[A-Z0-9]{2,12}$"
        },
        "positionSize": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "countGridSize": {
          "type": "number",
          "minimum": 1,
          "maximum": 100
        },
        "gridSize": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "percentBuyBackStep": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "takeProfit": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "stopLoss": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "percentProfit": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "percentFromBalance": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "candlePriceRange": {
          "type": "string",
          "enum": [
            "1m",
            "5m",
            "15m",
            "1h",
            "4h",
            "1d"
          ]
        },
        "isFibonacci": {
          "type": "boolean"
        },
        "isPercentTargetAfterTakeProfit": {
          "type": "boolean"
        },
        "isCapitalizeDeltaFromSale": {
          "type": "boolean"
        },
        "isCoinAccumulation": {
          "type": "boolean"
        },
        "isOnlyBuy": {
          "type": "boolean"
        },
        "percentTargetAfterTakeProfit": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "balanceDistribution": {
          "type": "boolean"
        }
      }
    }
  }
}
