{
  "name": "tonatiuh-trading-saas",
  "version": "1.17.15",
  "description": "Tonatiuh trading backend for SaaS and desktop deployments",
  "main": "build/index.js",
  "author": "Nick Whiteman",
  "license": "ISC",
  "engines": {
    "node": ">=20.17.0"
  },
  "husky": {
    "hook": {
      "pre-commit": "npm run lint"
    }
  },
  "scripts": {
    "build": "rimraf build && npx tsc",
    "start:dev": "npx nodemon",
    "start": "npm run build && node build/index.js",
    "start:ts-node": "npx ts-node src/index.ts",
    "db:migrate": "node build/saas/migrate.js",
    "db:migrate:dev": "npx ts-node src/saas/migrate.ts",
    "worker:saas": "node build/saas/worker.js",
    "worker:saas:dev": "npx ts-node src/saas/worker.ts",
    "worker:billing": "node build/saas/billing/renewals.js",
    "worker:billing:dev": "npx ts-node src/saas/billing/renewals.ts",
    "worker:email": "node build/saas/email/worker.js",
    "worker:email:dev": "npx ts-node src/saas/email/worker.ts",
    "test": "npm run build && node --test test/*.test.js",
    "test:integration": "node --test test-integration/*.test.js",
    "openapi:validate": "node --test test/openapi-contract.test.js",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/chai": "^4.3.20",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^18.19.130",
    "@types/nodemailer": "^7.0.12",
    "@types/pg": "^8.20.0",
    "@types/request": "^2.48.8",
    "@typescript-eslint/eslint-plugin": "^5.45.1",
    "@typescript-eslint/parser": "^5.45.1",
    "chai": "^4.3.6",
    "eslint": "^8.57.1",
    "husky": "^8.0.2",
    "prettier": "^2.8.0",
    "rimraf": "^3.0.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.7.4",
    "yaml": "^2.9.0"
  },
  "_moduleAliases": {
    "utils": "build/utils",
    "interface": "build/interface",
    "repository": "build/repository/*",
    "logger": "build/logger",
    "types": "build/types",
    "router": "build/router",
    "trading-service": "build/trading-service"
  },
  "dependencies": {
    "body-parser": "^1.20.0",
    "ccxt": "^4.1.51",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.1",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^9.14.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "sqlite3": "^6.0.1"
  }
}
