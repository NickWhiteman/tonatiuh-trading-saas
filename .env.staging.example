APP_MODE=web
# Keep production validation and security behavior enabled in staging.
ENV_RELEASE=prod
APP_ENV_FILE=.env.staging
HOST=0.0.0.0
PORT=3131
DOMAIN=api.staging.example.com
ACME_EMAIL=ops@example.com
BACKUP_RETENTION_DAYS=14
BACKUP_PRUNE=false
BACKUP_VOLUME_NAME=tonatiuh-staging-backups
CORS_ORIGINS=https://app.staging.example.com
PUBLIC_APP_URL=https://app.staging.example.com
TRUST_PROXY=1
LOG_LEVEL=info
TERMS_VERSION=staging-2026-07
PRIVACY_VERSION=staging-2026-07
TERMS_URL=https://app.staging.example.com/legal/terms/staging-2026-07
PRIVACY_URL=https://app.staging.example.com/legal/privacy/staging-2026-07
TERMS_SHA256=replace-with-64-lowercase-hex-characters
PRIVACY_SHA256=replace-with-64-lowercase-hex-characters
CONSENT_EVIDENCE_KEY_ID=staging-consent-v1
RETENTION_WORKER_INTERVAL_MS=86400000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=staging-mailer@example.com
SMTP_FROM=Tonatiuh Staging <staging@example.com>
DEFAULT_EMAIL_LOCALE=ru
YOOKASSA_SHOP_ID=
YOOKASSA_RETURN_URL=https://app.staging.example.com/billing/return
BILLING_GRACE_PERIOD_DAYS=7
BILLING_RETRY_SCHEDULE_HOURS=1,24,72,120
BILLING_RECONCILIATION_MINUTES=10
